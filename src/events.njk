---
layout: base.njk
title: Events
description: Upcoming events, day-longs, and retreats with Sit Raleigh in Raleigh, NC.
---

<div class="page-hero">
  <div class="page-hero-inner">
    <p class="page-eyebrow">Deepen your practice</p>
    <h1 class="page-headline">Events</h1>
    <p class="page-sub">Day-longs, outdoor sits, and special programs beyond the weekly schedule.</p>
    {% include "page-hero-icon.njk" %}
  </div>
</div>

{% set allEvents   = collections.events | whereType("Event") %}
{% set allRetreats = collections.events | whereType("Retreat") %}
{% set futureEvents = allEvents | sortByDate | futureOnly %}
{% set pastEvents   = allEvents | sortByDate | pastOnly | reverse %}

<section class="section section--parchment">
  <div class="section-inner">

    {# ── EVENTS ──────────────────────────────────────────── #}
    {% if futureEvents.length %}
    <div class="section-label">Coming up</div>
    <div class="events-grid">
      {% for event in futureEvents %}
      {% set md = event.data.date | monthDay %}
      <a href="{{ event.url }}" class="event-card">
        <div class="event-month">{{ md.month }}</div>
        <div class="event-day">{{ md.day }}</div>
        <div class="event-title">{{ event.data.title }}</div>
        <div class="event-meta">
          {% if event.data.time %}{{ event.data.time }}<br>{% endif %}
          {{ event.data.location_name }}
        </div>
        {% if event.data.eventbrite and event.data.eventbrite.url %}<span class="event-tag">Tickets available</span>{% endif %}
      </a>
      {% endfor %}
    </div>
    {% else %}
    <p style="color:var(--umber-lt);font-style:italic;">No upcoming events are scheduled right now. Check back soon.</p>
    {% endif %}

    {% if pastEvents.length %}
    <div class="section-label" style="margin-top:4rem;">Past events</div>
    <div class="events-grid">
      {% for event in pastEvents | limit(6) %}
      {% set md = event.data.date | monthDay %}
      <a href="{{ event.url }}" class="event-card" style="opacity:0.6;">
        <div class="event-month">{{ md.month }}</div>
        <div class="event-day">{{ md.day }}</div>
        <div class="event-title">{{ event.data.title }}</div>
        <div class="event-meta">{{ event.data.location_name }}</div>
      </a>
      {% endfor %}
    </div>
    {% endif %}

    {# ── RETREATS (subsection) ───────────────────────────── #}
    <div id="retreats" class="section-label" style="margin-top:4.5rem;">Retreats</div>
    {% set futureRetreats = allRetreats | sortByDate | futureOnly %}
    {% if futureRetreats.length %}
    <div class="events-grid">
      {% for event in futureRetreats %}
      {% set md = event.data.date | monthDay %}
      <a href="{{ event.url }}" class="event-card">
        <div class="event-month">{{ md.month }}</div>
        <div class="event-day">{{ md.day }}</div>
        <div class="event-title">{{ event.data.title }}</div>
        <div class="event-meta">
          {% if event.data.time %}{{ event.data.time }}<br>{% endif %}
          {{ event.data.location_name }}
        </div>
        {% if event.data.eventbrite and event.data.eventbrite.url %}<span class="event-tag">Tickets available</span>{% endif %}
      </a>
      {% endfor %}
    </div>
    {% else %}
    <p style="color:var(--umber-lt);font-style:italic;">No retreats are scheduled at the moment. Check back soon, or <a href="/contact/" style="color:var(--gold)">reach out</a> to be notified when the next one opens.</p>
    {% endif %}

  </div>
</section>
