---
layout: base.njk
title: Blog
description: Weekly reflections from Sit Raleigh, expanding on each week's teaching, guided by Cary Keishin Brief.
---

<div class="page-hero">
  <div class="page-hero-inner">
    <p class="page-eyebrow">Weekly reflections</p>
    <div class="blog-hero-row">
      <h1 class="page-headline">Blog</h1>
      <img src="/images/sit-raleigh-logo.png" alt="" class="blog-hero-logo" />
    </div>
    <p class="page-sub">Each week, we expand on the teaching from our newsletter &mdash; a place to sit with the ideas a little longer.</p>
  </div>
</div>

<section class="section section--parchment">
  <div class="section-inner">
    {% set posts = collections.blog | sortByDate | reverse %}
    {% if posts.length %}
    {% set yearGroups = posts | groupByYear %}
    <div class="blog-layout">
      <aside class="blog-year-filter" aria-label="Jump to year">
        <div class="section-label" style="margin-bottom:14px;">Jump to year</div>
        <div class="year-filter-list" id="yearFilterList">
          {% for group in yearGroups %}
          <a href="#year-{{ group.year }}" class="year-filter-btn{% if loop.first %} is-active{% endif %}" data-year="{{ group.year }}">
            {{ group.year }} <span class="year-filter-count">{{ group.posts.length }}</span>
          </a>
          {% endfor %}
          <a href="/fun/" class="year-filter-btn year-filter-btn--fun">
            Fun Stuff {% if jokes.jokes.length %}<span class="year-filter-count">{{ jokes.jokes.length }}</span>{% endif %}
          </a>
        </div>
      </aside>

      <div class="blog-main">
        <div class="blog-flag-divider">
          <img src="/images/prayer-flags.png" alt="" class="blog-flag-img" loading="lazy">
        </div>

        {% for group in yearGroups %}
        <section class="blog-year-group" id="year-{{ group.year }}" data-year="{{ group.year }}">
          <h2 class="blog-year-heading">{{ group.year }}</h2>
          <div class="blog-grid">
            {% for post in group.posts %}
            <a href="{{ post.url }}" class="blog-card">
              {% if post.data.featured_image %}
              <div class="blog-card-img" style="background-image:url('{{ post.data.featured_image }}');"></div>
              {% endif %}
              <div class="blog-card-body">
                <div class="blog-card-date">{{ post.data.date | shortDate }}{% if post.data.author %} &middot; {{ post.data.author }}{% endif %}</div>
                <h3 class="blog-card-title">{{ post.data.title }}</h3>
                {% if post.data.summary %}<p class="blog-card-summary">{{ post.data.summary }}</p>{% endif %}
                <span class="blog-card-more">Read &rarr;</span>
              </div>
            </a>
            {% endfor %}
          </div>
        </section>
        {% if not loop.last %}
        <div class="blog-flag-divider">
          <img src="/images/prayer-flags.png" alt="" class="blog-flag-img" loading="lazy">
        </div>
        {% endif %}
        {% endfor %}
      </div>
    </div>

    <script>
      (function () {
        var links = Array.prototype.slice.call(document.querySelectorAll("#yearFilterList .year-filter-btn"));
        var sections = Array.prototype.slice.call(document.querySelectorAll(".blog-year-group"));
        if (!links.length || !sections.length || !("IntersectionObserver" in window)) return;

        var observer = new IntersectionObserver(function (entries) {
          entries.forEach(function (entry) {
            if (entry.isIntersecting) {
              var year = entry.target.getAttribute("data-year");
              links.forEach(function (link) {
                link.classList.toggle("is-active", link.getAttribute("data-year") === year);
              });
            }
          });
        }, { rootMargin: "-40% 0px -55% 0px", threshold: 0 });

        sections.forEach(function (section) { observer.observe(section); });
      })();
    </script>
    {% else %}
    <p style="text-align:center;color:var(--umber-lt);">No posts yet &mdash; check back soon.</p>
    {% endif %}
  </div>
</section>
