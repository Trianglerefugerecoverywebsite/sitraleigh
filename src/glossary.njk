---
layout: base.njk
title: Pāli Glossary
description: A reference guide to Pāli terms used in Theravāda Buddhist meditation practice at Sit Raleigh.
---

<div class="page-hero">
  <div class="page-hero-inner">
    <p class="page-eyebrow">The language of the teachings</p>
    <h1 class="page-headline">Pāli Glossary</h1>
    <p class="page-sub">Pāli is the ancient language of the earliest Buddhist texts. These terms come up often in sits and talks — this reference is here whenever you need it.</p>
    {% include "page-hero-icon.njk" %}
  </div>
</div>

<section class="section section--white">
  <div class="section-inner">

    {# ── Filter bar ──────────────────────────────────── #}
    <div class="glossary-controls" role="search" aria-label="Filter glossary terms">
      <div class="glossary-search-wrap">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true" style="position:absolute;left:14px;top:50%;transform:translateY(-50%);stroke:var(--gold-lt);">
          <circle cx="11" cy="11" r="7"/><line x1="16.5" y1="16.5" x2="22" y2="22"/>
        </svg>
        <input
          type="search"
          id="glossary-search"
          placeholder="Search terms, translations, definitions…"
          aria-label="Search glossary"
          autocomplete="off"
        />
      </div>
      <div class="glossary-cats" role="group" aria-label="Filter by category">
        <button class="cat-btn active" data-cat="all">All</button>
        {% set cats = [] %}
        {% for term in glossary.terms %}
          {% if term.category not in cats %}
            {% set cats = (cats.push(term.category), cats) %}
          {% endif %}
        {% endfor %}
        {% for cat in cats | unique %}
        <button class="cat-btn" data-cat="{{ cat }}">{{ cat }}</button>
        {% endfor %}
      </div>
    </div>

    {# ── Terms list ──────────────────────────────────── #}
    <div id="glossary-list" class="glossary-list" aria-live="polite">
      {% for term in glossary.terms | sort(attribute="term") %}
      <div
        class="glossary-entry"
        data-term="{{ term.term | lower }}"
        data-translation="{{ term.translation | lower }}"
        data-definition="{{ term.definition | lower }}"
        data-cat="{{ term.category }}"
      >
        <div class="glossary-entry-header">
          <div class="glossary-term-group">
            <span class="glossary-term">{{ term.term }}</span>
            {% if term.pronunciation %}
            <span class="glossary-pronunciation">/ {{ term.pronunciation }} /</span>
            {% endif %}
          </div>
          <span class="glossary-cat-badge">{{ term.category }}</span>
        </div>
        <div class="glossary-translation">{{ term.translation }}</div>
        <p class="glossary-definition">{{ term.definition }}</p>
      </div>
      {% endfor %}
    </div>

    <p id="glossary-empty" class="glossary-empty" hidden>
      No terms match your search. Try a different word or clear the filter.
    </p>

  </div>
</section>

{# ── Mailing list CTA ────────────────────────────────── #}

<style>
/* ── Glossary controls ─────────────────────── */
.glossary-controls {
  display: flex;
  flex-direction: column;
  gap: 14px;
  margin-bottom: 2.5rem;
}
.glossary-search-wrap {
  position: relative;
}
#glossary-search {
  width: 100%;
  padding: 12px 14px 12px 42px;
  font-family: var(--font-body);
  font-size: 15px;
  color: var(--umber);
  background: var(--parchment);
  border: 0.5px solid rgba(122,96,48,0.25);
  border-radius: var(--radius-md);
  outline: none;
  transition: border-color 0.2s;
}
#glossary-search:focus { border-color: var(--gold); }
#glossary-search::placeholder { color: var(--gold-lt); }

.glossary-cats {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
}
.cat-btn {
  font-family: var(--font-body);
  font-size: 10px;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  padding: 6px 14px;
  border-radius: 20px;
  border: 0.5px solid rgba(122,96,48,0.25);
  background: transparent;
  color: var(--umber-lt);
  cursor: pointer;
  transition: background 0.15s, color 0.15s, border-color 0.15s;
}
.cat-btn:hover { border-color: var(--gold); color: var(--gold); }
.cat-btn.active { background: var(--gold); color: var(--parchment); border-color: var(--gold); }

/* ── Glossary entries ──────────────────────── */
.glossary-list {
  display: flex;
  flex-direction: column;
  gap: 0;
  border: 0.5px solid rgba(122,96,48,0.15);
  border-radius: var(--radius-lg);
  overflow: hidden;
}
.glossary-entry {
  padding: 22px 28px;
  border-bottom: 0.5px solid rgba(122,96,48,0.12);
  transition: background 0.15s;
}
.glossary-entry:last-child { border-bottom: none; }
.glossary-entry:hover { background: var(--parchment); }

.glossary-entry-header {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  gap: 12px;
  margin-bottom: 4px;
  flex-wrap: wrap;
}
.glossary-term-group {
  display: flex;
  align-items: baseline;
  gap: 10px;
  flex-wrap: wrap;
}
.glossary-term {
  font-family: var(--font-display);
  font-size: 22px;
  font-weight: 400;
  color: var(--umber);
  line-height: 1;
}
.glossary-pronunciation {
  font-size: 12px;
  color: var(--gold-lt);
  font-style: italic;
  letter-spacing: 0.02em;
}
.glossary-cat-badge {
  font-size: 9px;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--gold);
  background: rgba(122,96,48,0.08);
  padding: 3px 10px;
  border-radius: 20px;
  white-space: nowrap;
  flex-shrink: 0;
}
.glossary-translation {
  font-size: 12px;
  letter-spacing: 0.06em;
  text-transform: uppercase;
  color: var(--gold);
  margin-bottom: 8px;
}
.glossary-definition {
  font-size: 14px;
  line-height: 1.8;
  color: var(--umber-lt);
  max-width: 680px;
}

/* highlight matched search text */
.glossary-definition mark,
.glossary-term mark {
  background: rgba(122,96,48,0.18);
  color: inherit;
  border-radius: 2px;
  padding: 0 1px;
}

.glossary-empty {
  text-align: center;
  padding: 3rem;
  color: var(--gold-lt);
  font-style: italic;
}

@media (max-width: 600px) {
  .glossary-entry { padding: 18px 16px; }
  .glossary-entry-header { flex-direction: column; gap: 6px; }
}
</style>

<script>
(function() {
  const search  = document.getElementById('glossary-search');
  const list    = document.getElementById('glossary-list');
  const empty   = document.getElementById('glossary-empty');
  const entries = Array.from(list.querySelectorAll('.glossary-entry'));
  const catBtns = Array.from(document.querySelectorAll('.cat-btn'));

  let activeCat = 'all';
  let query     = '';

  function filterAll() {
    let visible = 0;
    const q = query.trim().toLowerCase();

    entries.forEach(entry => {
      const matchCat  = activeCat === 'all' || entry.dataset.cat === activeCat;
      const matchText = !q ||
        entry.dataset.term.includes(q) ||
        entry.dataset.translation.includes(q) ||
        entry.dataset.definition.includes(q);

      const show = matchCat && matchText;
      entry.hidden = !show;
      if (show) visible++;

      // Highlight in definition
      if (show && q) {
        const def  = entry.querySelector('.glossary-definition');
        const term = entry.querySelector('.glossary-term');
        [def, term].forEach(el => {
          if (!el) return;
          el.innerHTML = el.textContent.replace(
            new RegExp('(' + q.replace(/[.*+?^${}()|[\]\\]/g, '\\$&') + ')', 'gi'),
            '<mark>$1</mark>'
          );
        });
      } else {
        // Reset highlights
        const def  = entry.querySelector('.glossary-definition');
        const term = entry.querySelector('.glossary-term');
        if (def)  def.textContent  = def.textContent;
        if (term) term.textContent = term.textContent;
      }
    });

    empty.hidden = visible > 0;
  }

  search.addEventListener('input', e => {
    query = e.target.value;
    filterAll();
  });

  catBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      catBtns.forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      activeCat = btn.dataset.cat;
      filterAll();
    });
  });
})();
</script>
{% if mailing_list.enabled %}
<section class="mailing-list-section" aria-labelledby="ml-heading">
  <div class="mailing-list-inner">
    <div class="ml-lotus" aria-hidden="true">
      <svg width="40" height="40" viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M20 34 C20 34 8 26 8 18 C8 12 13 8 20 8 C27 8 32 12 32 18 C32 26 20 34 20 34Z" stroke="rgba(212,184,122,0.4)" stroke-width="0.8" fill="none"/>
        <path d="M20 34 C20 34 10 22 13 15 C15 10 20 8 20 8 C20 8 25 10 27 15 C30 22 20 34 20 34Z" stroke="rgba(212,184,122,0.55)" stroke-width="0.8" fill="none"/>
        <path d="M20 34 C20 34 12 20 16 13 C18 9 20 8 20 8 C20 8 22 9 24 13 C28 20 20 34 20 34Z" stroke="rgba(212,184,122,0.7)" stroke-width="0.8" fill="rgba(122,96,48,0.06)"/>
        <circle cx="20" cy="20" r="2" fill="rgba(212,184,122,0.6)"/>
      </svg>
    </div>

    <h2 class="ml-heading" id="ml-heading">{{ mailing_list.heading }}</h2>
    <p class="ml-sub">{{ mailing_list.subheading }}</p>

    {% if mailing_list.provider == "mailchimp" and mailing_list.form_action %}
    {# ── Mailchimp embed ─────────────────────────── #}
    <form
      action="{{ mailing_list.form_action }}"
      method="post"
      target="_blank"
      class="ml-form"
      novalidate
    >
      <div class="ml-input-row">
        <label for="ml-email" class="sr-only">Email address</label>
        <input
          type="email"
          name="EMAIL"
          id="ml-email"
          placeholder="{{ mailing_list.placeholder }}"
          required
          autocomplete="email"
        />
        {# Mailchimp bot-buster — do not remove #}
        <div aria-hidden="true" style="position:absolute;left:-5000px;">
          <input type="text" name="b_REPLACE_ME" tabindex="-1" value="" />
        </div>
        <button type="submit" class="ml-btn">{{ mailing_list.button_label }}</button>
      </div>
    </form>

    {% elif mailing_list.provider == "convertkit" and mailing_list.form_action %}
    {# ── ConvertKit embed ────────────────────────── #}
    <form
      action="{{ mailing_list.form_action }}"
      method="post"
      class="ml-form"
      novalidate
    >
      <div class="ml-input-row">
        <label for="ml-email-ck" class="sr-only">Email address</label>
        <input
          type="email"
          name="email_address"
          id="ml-email-ck"
          placeholder="{{ mailing_list.placeholder }}"
          required
          autocomplete="email"
        />
        <button type="submit" class="ml-btn">{{ mailing_list.button_label }}</button>
      </div>
    </form>

    {% else %}
    {# ── No provider yet — placeholder ──────────── #}
    <div class="ml-form">
      <div class="ml-input-row">
        <label for="ml-email-ph" class="sr-only">Email address</label>
        <input
          type="email"
          id="ml-email-ph"
          placeholder="{{ mailing_list.placeholder }}"
          autocomplete="email"
          disabled
          title="Mailing list coming soon"
        />
        <button type="button" class="ml-btn" disabled>{{ mailing_list.button_label }}</button>
      </div>
      <p class="ml-coming-soon">Mailing list setup in progress — check back soon.</p>
    </div>
    {% endif %}

    <p class="ml-fine-print">{{ mailing_list.fine_print }}</p>
  </div>
</section>
{% endif %}

<style>
.sr-only {
  position: absolute;
  width: 1px;
  height: 1px;
  padding: 0;
  margin: -1px;
  overflow: hidden;
  clip: rect(0,0,0,0);
  white-space: nowrap;
  border: 0;
}
.mailing-list-section {
  background: var(--umber);
  padding: clamp(3rem, 6vw, 5rem) var(--pad);
}
.mailing-list-inner {
  max-width: 540px;
  margin: 0 auto;
  text-align: center;
}
.ml-lotus {
  margin-bottom: 20px;
  display: flex;
  justify-content: center;
}
.ml-heading {
  font-family: var(--font-display);
  font-size: clamp(26px, 4vw, 36px);
  font-weight: 300;
  color: var(--parchment);
  margin-bottom: 12px;
  line-height: 1.2;
}
.ml-sub {
  font-size: 14px;
  line-height: 1.8;
  color: var(--gold-lt);
  margin-bottom: 28px;
  max-width: 400px;
  margin-left: auto;
  margin-right: auto;
}
.ml-form {
  width: 100%;
}
.ml-input-row {
  display: flex;
  gap: 0;
  border: 0.5px solid rgba(212,184,122,0.3);
  border-radius: var(--radius-md);
  overflow: hidden;
  background: rgba(255,255,255,0.05);
}
.ml-input-row input[type="email"] {
  flex: 1;
  padding: 13px 18px;
  font-family: var(--font-body);
  font-size: 14px;
  background: transparent;
  border: none;
  color: var(--parchment);
  outline: none;
  min-width: 0;
}
.ml-input-row input[type="email"]::placeholder { color: rgba(168,144,96,0.6); }
.ml-input-row input[type="email"]:disabled { opacity: 0.5; cursor: not-allowed; }
.ml-btn {
  flex-shrink: 0;
  padding: 13px 22px;
  font-family: var(--font-body);
  font-size: 11px;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  background: var(--gold);
  color: var(--parchment);
  border: none;
  cursor: pointer;
  transition: background 0.2s;
}
.ml-btn:hover:not(:disabled) { background: var(--gold-pale); color: var(--umber); }
.ml-btn:disabled { opacity: 0.5; cursor: not-allowed; }
.ml-fine-print {
  font-size: 11px;
  color: rgba(122,96,48,0.5);
  margin-top: 14px;
  letter-spacing: 0.03em;
}
.ml-coming-soon {
  font-size: 12px;
  color: rgba(168,144,96,0.6);
  margin-top: 10px;
  font-style: italic;
}

@media (max-width: 480px) {
  .ml-input-row { flex-direction: column; }
  .ml-btn { border-radius: 0; }
}
</style>
