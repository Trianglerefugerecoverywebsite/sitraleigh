---
layout: base.njk
title: Teachings
description: Written teachings, recorded dharma talks, and guided meditations from Sit Raleigh, guided by Cary Keishin Brief.
---

<div class="page-hero">
  <div class="page-hero-inner">
    <p class="page-eyebrow">Study &amp; practice</p>
    <h1 class="page-headline">Teachings</h1>
    <p class="page-sub">Foundational teachings to read and return to, alongside recorded talks and guided meditations to practice with.</p>
    {% include "page-hero-icon.njk" %}
  </div>
</div>

{# ── WRITTEN TEACHINGS ─────────────────────────────────── #}
<section id="written" class="section section--white" aria-labelledby="written-heading">
  <div class="section-inner">
    <div class="section-label" id="written-heading">Written Teachings</div>
    <div class="written-grid">
      {% for t in collections.written | sortByOrder %}
      <a href="{{ t.url }}" class="written-card">
        <h2 class="written-card-title">{{ t.data.title }}</h2>
        {% if t.data.summary %}<p class="written-card-summary">{{ t.data.summary }}</p>{% endif %}
        <span class="written-card-more">Read &rarr;</span>
      </a>
      {% endfor %}
    </div>
  </div>
</section>

{# ── RECORDED TALKS & MEDITATIONS ──────────────────────── #}
<section id="recorded" class="section section--parchment" aria-labelledby="recorded-heading">
  <div class="section-inner">
    <div class="section-label" id="recorded-heading">Recorded Talks &amp; Meditations</div>
    {% set talks = collections.teachings | sortByDate | reverse %}
    {% if talks.length %}
    <div class="teachings-grid">
      {% for teaching in talks %}
      <a href="{{ teaching.url }}" class="teaching-row">
        <div class="play-btn" aria-hidden="true">
          <svg viewBox="0 0 24 24" stroke-width="1.5" fill="none" stroke="currentColor"><polygon points="5,3 19,12 5,21"/></svg>
        </div>
        <div class="teaching-info">
          <div class="teaching-title">{{ teaching.data.title }}</div>
          <div class="teaching-meta">
            {{ teaching.data.date | shortDate }}
            {% if teaching.data.duration %}&middot; {{ teaching.data.duration }}{% endif %}
          </div>
        </div>
      </a>
      {% endfor %}
    </div>
    {% else %}
    <p style="color:var(--umber-lt);">Recordings coming soon.</p>
    {% endif %}
  </div>
</section>
