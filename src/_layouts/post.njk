---
layout: base.njk
---

<section class="section section--white post-section">
  <div class="post-layout">

    {# ── Sticky title column ──────────────────────────── #}
    <aside class="post-aside">
      <p class="page-eyebrow" style="margin-bottom:12px;">
        <a href="/blog/" style="color:var(--gold);text-decoration:none;">&larr; All posts</a>
      </p>
      <h1 class="post-title">{{ title }}</h1>
      <p class="post-meta">{{ date | shortDate }}{% if author %} &middot; {{ author }}{% endif %}</p>
      {% if newsletter_teaching %}
      <p class="post-continuity">Continuing this week&rsquo;s teaching:<br><em>{{ newsletter_teaching }}</em></p>
      {% endif %}
    </aside>

    {# ── Scrolling content column ─────────────────────── #}
    <div class="post-main">
      {% if featured_image %}
      <img src="{{ featured_image }}" alt="{{ title }}" class="post-featured" />
      {% endif %}

      {% if instagram_url %}
      <div class="post-instagram">
        <blockquote class="instagram-media" data-instgrm-permalink="{{ instagram_url }}" data-instgrm-version="14"></blockquote>
      </div>
      <script async src="//www.instagram.com/embed.js"></script>
      {% endif %}

      <div class="rich-text">
        {{ content | inlineThumbs | safe }}
      </div>

      {% if gallery and gallery.length %}
      <div class="post-gallery">
        {% for item in gallery %}
        {% if item.image %}
        <img src="{{ item.image }}"
             alt="{{ item.caption | default(title, true) }}"
             class="gallery-thumb"
             tabindex="0"
             role="button"
             aria-haspopup="dialog"
             loading="lazy">
        {% endif %}
        {% endfor %}
      </div>
      {% endif %}

      {% if tags %}
      <div class="post-tags">
        {% for tag in tags %}
        {% if tag != "blog" %}
        <span class="post-tag">{{ tag }}</span>
        {% endif %}
        {% endfor %}
      </div>
      {% endif %}

      <p style="margin-top:2.5rem;">
        <a href="/blog/" style="font-size:11px;letter-spacing:0.1em;text-transform:uppercase;color:var(--gold);text-decoration:none;border-bottom:0.5px solid var(--gold);padding-bottom:1px;">&larr; Back to all posts</a>
      </p>
    </div>

  </div>
</section>

<div class="modal-overlay image-lightbox-overlay" id="imageLightboxOverlay" onclick="closeImageLightbox()">
  <div class="image-lightbox-panel" onclick="event.stopPropagation()">
    <button type="button" class="modal-close" id="imageLightboxClose" onclick="closeImageLightbox()" aria-label="Close">&times;</button>
    <img id="imageLightboxImg" src="" alt="" class="image-lightbox-img">
    <p id="imageLightboxCaption" class="image-lightbox-caption"></p>
  </div>
</div>

<script>
  var imageLightboxLastFocused = null;

  function openImageLightbox(src, caption) {
    if (!src) return;
    imageLightboxLastFocused = document.activeElement;
    document.getElementById("imageLightboxImg").src = src;
    document.getElementById("imageLightboxImg").alt = caption || "";
    var capEl = document.getElementById("imageLightboxCaption");
    capEl.textContent = caption || "";
    capEl.style.display = caption ? "block" : "none";
    var overlay = document.getElementById("imageLightboxOverlay");
    overlay.classList.add("is-open");
    document.body.style.overflow = "hidden";
    document.getElementById("imageLightboxClose").focus();
    document.addEventListener("keydown", imageLightboxKeydown);
  }

  function closeImageLightbox() {
    document.getElementById("imageLightboxOverlay").classList.remove("is-open");
    document.getElementById("imageLightboxImg").src = "";
    document.body.style.overflow = "";
    document.removeEventListener("keydown", imageLightboxKeydown);
    if (imageLightboxLastFocused) imageLightboxLastFocused.focus();
  }

  function imageLightboxKeydown(e) {
    if (e.key === "Escape") closeImageLightbox();
  }

  document.addEventListener("click", function (e) {
    var img = e.target.closest(".gallery-thumb, .inline-thumb");
    if (img && img.tagName === "IMG") {
      openImageLightbox(img.currentSrc || img.src, img.alt || "");
    }
  });

  document.addEventListener("keydown", function (e) {
    if ((e.key === "Enter" || e.key === " ") &&
        e.target.matches && e.target.matches(".gallery-thumb, .inline-thumb")) {
      e.preventDefault();
      openImageLightbox(e.target.currentSrc || e.target.src, e.target.alt || "");
    }
  });
</script>
