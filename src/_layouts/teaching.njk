---
layout: base.njk
---

<div class="page-hero">
  <div class="page-hero-inner">
    <p class="page-eyebrow">
      <a href="/teachings/" style="color:var(--gold);text-decoration:none;">&larr; All teachings</a>
    </p>
    <h1 class="page-headline">{{ title }}</h1>
    <p style="margin-top:14px;font-size:13px;color:var(--gold-lt);">
      {{ date | shortDate }}
      {% if duration %}&middot; {{ duration }}{% endif %}
    </p>
  </div>
</div>

<section class="section section--white">
  <div class="section-inner" style="max-width:680px;">

    {% if featured_image %}
    <img src="{{ featured_image }}" alt="{{ title }}" class="post-featured" />
    {% endif %}

    {# ── Media player ───────────────────────────────────── #}
    {% if media_type == "youtube" %}
    <div style="position:relative;padding-bottom:56.25%;height:0;overflow:hidden;border-radius:var(--radius-md);margin-bottom:2rem;">
      <iframe
        src="{{ media_url | replace('watch?v=', 'embed/') }}"
        style="position:absolute;top:0;left:0;width:100%;height:100%;border:none;"
        allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
        allowfullscreen
        title="{{ title }}"
      ></iframe>
    </div>

    {% elif media_type == "video" %}
    <video controls style="width:100%;border-radius:var(--radius-md);margin-bottom:2rem;">
      <source src="{{ media_url }}" />
      Your browser does not support video playback.
    </video>

    {% elif media_type == "link" and media_url %}
    <a href="{{ media_url }}" target="_blank" rel="noopener" class="btn-primary" style="margin-bottom:2rem;">Listen on Insight Timer &rarr;</a>

    {% elif media_url %}
    <div style="background:var(--parchment-2);border:0.5px solid rgba(122,96,48,0.2);border-radius:var(--radius-md);padding:24px;margin-bottom:2rem;display:flex;align-items:center;gap:16px;">
      <audio controls style="flex:1;">
        <source src="{{ media_url }}" />
        Your browser does not support audio playback.
      </audio>
    </div>
    {% endif %}

    {% if description %}
    <div class="rich-text">
      {{ description | nl2br | safe }}
    </div>
    {% endif %}

    {% if tags %}
    <div style="margin-top:1.5rem;display:flex;flex-wrap:wrap;gap:8px;">
      {% for tag in tags %}
      {% if tag != "teachings" %}
      <span style="font-size:10px;letter-spacing:0.1em;text-transform:uppercase;background:rgba(122,96,48,0.1);color:var(--gold);padding:4px 12px;border-radius:20px;">{{ tag }}</span>
      {% endif %}
      {% endfor %}
    </div>
    {% endif %}
  </div>
</section>
