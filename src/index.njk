---
layout: base.njk
title: false
---

{# ── LOGO BANNER (home only) ────────────────────────────── #}
<section class="home-logo-hero" aria-label="Sit Raleigh Meditation Society">
  <img src="/images/sit-raleigh-logo.png" alt="Sit Raleigh Meditation Society" class="home-logo" />
</section>

{# ── HERO ──────────────────────────────────────────────── #}
<section aria-label="Welcome">
  <div class="hero">
    <div class="hero-left">
      <p class="hero-eyebrow">{{ settings.tagline }}</p>
      <h1 class="hero-headline">
        Still the<br>mind.<br><em>Open</em> the<br>heart.
      </h1>
      <p class="hero-sub">
        Weekly sits, dharma talks, and guided practice rooted in the early Buddhist teachings.
        All are welcome — no experience required.
      </p>
    </div>
    <div class="hero-divider" aria-hidden="true"></div>
    <div class="hero-right">
      <div class="this-week-card">
        <div class="this-week-label">This week&rsquo;s teaching</div>
        <h2 class="this-week-title">{{ this_week.title }}</h2>
        <div class="this-week-meta">
          <span>
            <svg viewBox="0 0 24 24" stroke-width="1.5" aria-hidden="true"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
            {{ this_week.date | dateDisplay }}{% if this_week.time %} &middot; {{ this_week.time }}{% endif %}
          </span>
          <span>
            <svg viewBox="0 0 24 24" stroke-width="1.5" aria-hidden="true"><path d="M12 21C12 21 5 14.5 5 9a7 7 0 0114 0c0 5.5-7 12-7 12z"/><circle cx="12" cy="9" r="2.5"/></svg>
            {{ this_week.location_name }}{% if this_week.location_address %}, {{ this_week.location_address }}{% endif %}
          </span>
          {% if this_week.dana_note %}
          <span>
            <svg viewBox="0 0 24 24" stroke-width="1.5" aria-hidden="true"><circle cx="12" cy="12" r="9"/><path d="M12 7v10M9.5 9.5h4a1.5 1.5 0 010 3H10a1.5 1.5 0 000 3h4.5"/></svg>
            {{ this_week.dana_note }}
          </span>
          {% endif %}
        </div>
        {% if this_week.description %}
        <p class="this-week-desc">{{ this_week.description }}</p>
        {% endif %}
        {% if this_week.registration_link %}
        <a href="{{ this_week.registration_link }}" class="btn-primary" target="_blank" rel="noopener">Register &rarr;</a>
        {% else %}
        <a href="/schedule/" class="btn-primary">See full schedule &rarr;</a>
        {% endif %}
      </div>
    </div>
  </div>
</section>

{# ── SCHEDULE STRIP ────────────────────────────────────── #}
<div class="schedule-strip" aria-label="Weekly sit times">
  <div class="schedule-inner">
    {% for sit in schedule.sits %}
    <div class="sched-item">
      <div class="sched-dot" aria-hidden="true"></div>
      <div class="sched-day">{{ sit.day }}</div>
      <div class="sched-time">{{ sit.time }}</div>
      <div class="sched-loc">{{ sit.location }}</div>
    </div>
    {% endfor %}
  </div>
</div>

{# ── UPCOMING EVENTS ───────────────────────────────────── #}
{% set upcomingEvents = collections.events | sortByDate | futureOnly | limit(3) %}
{% if upcomingEvents.length %}
<section class="section section--parchment" aria-labelledby="events-heading">
  <div class="section-inner">
    <div class="section-label" id="events-heading">Upcoming events &amp; retreats</div>
    <div class="events-grid">
      {% for event in upcomingEvents %}
      {% set md = event.data.date | monthDay %}
      <a href="{{ event.url }}" class="event-card">
        <div class="event-month">{{ md.month }}</div>
        <div class="event-day">{{ md.day }}</div>
        <div class="event-title">{{ event.data.title }}</div>
        <div class="event-meta">
          {% if event.data.time %}{{ event.data.time }}<br>{% endif %}
          {{ event.data.location_name }}
        </div>
        {% if event.data.eventbrite and event.data.eventbrite.url %}
        <span class="event-tag">Tickets available</span>
        {% endif %}
      </a>
      {% endfor %}
    </div>
    <p style="margin-top:24px">
      <a href="/events/" class="btn-outline">All events &rarr;</a>
    </p>
  </div>
</section>
{% endif %}

{# ── RECENT TEACHINGS ──────────────────────────────────── #}
{% set recentTeachings = collections.teachings | sortByDate | reverse | limit(4) %}
{% if recentTeachings.length %}
<section class="section section--white" aria-labelledby="teachings-heading">
  <div class="section-inner">
    <div class="section-label" id="teachings-heading">Recorded teachings</div>
    <div class="teachings-grid">
      {% for teaching in recentTeachings %}
      <a href="{{ teaching.url }}" class="teaching-row">
        <div class="play-btn" aria-hidden="true">
          <svg viewBox="0 0 24 24" stroke-width="1.5"><polygon points="5,3 19,12 5,21" fill="none"/></svg>
        </div>
        <div class="teaching-info">
          <div class="teaching-title">{{ teaching.data.title }}</div>
          <div class="teaching-meta">
            {{ teaching.data.date | shortDate }}
            {% if teaching.data.duration %}&middot; {{ teaching.data.duration }}{% endif %}
          </div>
        </div>
      </a>
      {% endfor %}
    </div>
    <p style="margin-top:24px">
      <a href="/teachings/" class="btn-outline">All teachings &rarr;</a>
    </p>
  </div>
</section>
{% endif %}

{# ── MAILING LIST ──────────────────────────────────────── #}

{# ── ABOUT + LOCATIONS ─────────────────────────────────── #}
<section class="section section--dark" aria-labelledby="about-heading">
  <div class="about-map-grid">
    <div>
      <div class="section-label" id="about-heading">About {{ about.teacher_name }}</div>
      {% if about.photo %}
      <img src="{{ about.photo }}" alt="{{ about.teacher_name }}" class="about-photo" />
      {% endif %}
      {% if about.pull_quote %}
      <blockquote class="about-pull-quote">&ldquo;{{ about.pull_quote }}&rdquo;</blockquote>
      {% endif %}
      <p class="about-body">{{ about.bio_short }}</p>
      <p style="margin-top:20px">
        <a href="/about/" style="font-size:11px;letter-spacing:0.1em;text-transform:uppercase;color:var(--gold);text-decoration:none;border-bottom:0.5px solid var(--gold);padding-bottom:1px;">
          Full bio &rarr;
        </a>
      </p>
    </div>
    <div>
      <div class="section-label">Practice locations</div>
      <div class="locations-stack">
        {% for place in locations.places %}
        <div class="location-card">
          <div class="location-name">{{ place.name }}</div>
          <div class="location-addr">{{ place.address }}</div>
          {% if place.notes %}
          <div class="location-addr" style="margin-top:4px;font-style:italic;">{{ place.notes }}</div>
          {% endif %}
          {% if place.map_link %}
          <a href="{{ place.map_link }}" class="location-link" target="_blank" rel="noopener">Open in Maps &rarr;</a>
          {% endif %}
        </div>
        {% endfor %}
      </div>
    </div>
  </div>
</section>
{% if mailing_list.enabled %}
<section class="mailing-list-section" aria-labelledby="ml-heading">
  <div class="mailing-list-inner">
    <div class="ml-lotus" aria-hidden="true">
      <svg width="40" height="40" viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M20 34 C20 34 8 26 8 18 C8 12 13 8 20 8 C27 8 32 12 32 18 C32 26 20 34 20 34Z" stroke="rgba(212,184,122,0.4)" stroke-width="0.8" fill="none"/>
        <path d="M20 34 C20 34 10 22 13 15 C15 10 20 8 20 8 C20 8 25 10 27 15 C30 22 20 34 20 34Z" stroke="rgba(212,184,122,0.55)" stroke-width="0.8" fill="none"/>
        <path d="M20 34 C20 34 12 20 16 13 C18 9 20 8 20 8 C20 8 22 9 24 13 C28 20 20 34 20 34Z" stroke="rgba(212,184,122,0.7)" stroke-width="0.8" fill="rgba(122,96,48,0.06)"/>
        <circle cx="20" cy="20" r="2" fill="rgba(212,184,122,0.6)"/>
      </svg>
    </div>

    <h2 class="ml-heading" id="ml-heading">{{ mailing_list.heading }}</h2>
    <p class="ml-sub">{{ mailing_list.subheading }}</p>

    {% if mailing_list.provider == "mailchimp" and mailing_list.form_action %}
    {# ── Mailchimp embed ─────────────────────────── #}
    <form
      action="{{ mailing_list.form_action }}"
      method="post"
      target="_blank"
      class="ml-form"
      novalidate
    >
      <div class="ml-input-row">
        <label for="ml-email" class="sr-only">Email address</label>
        <input
          type="email"
          name="EMAIL"
          id="ml-email"
          placeholder="{{ mailing_list.placeholder }}"
          required
          autocomplete="email"
        />
        {# Mailchimp bot-buster — do not remove #}
        <div aria-hidden="true" style="position:absolute;left:-5000px;">
          <input type="text" name="b_REPLACE_ME" tabindex="-1" value="" />
        </div>
        <button type="submit" class="ml-btn">{{ mailing_list.button_label }}</button>
      </div>
    </form>

    {% elif mailing_list.provider == "convertkit" and mailing_list.form_action %}
    {# ── ConvertKit embed ────────────────────────── #}
    <form
      action="{{ mailing_list.form_action }}"
      method="post"
      class="ml-form"
      novalidate
    >
      <div class="ml-input-row">
        <label for="ml-email-ck" class="sr-only">Email address</label>
        <input
          type="email"
          name="email_address"
          id="ml-email-ck"
          placeholder="{{ mailing_list.placeholder }}"
          required
          autocomplete="email"
        />
        <button type="submit" class="ml-btn">{{ mailing_list.button_label }}</button>
      </div>
    </form>

    {% else %}
    {# ── No provider yet — placeholder ──────────── #}
    <div class="ml-form">
      <div class="ml-input-row">
        <label for="ml-email-ph" class="sr-only">Email address</label>
        <input
          type="email"
          id="ml-email-ph"
          placeholder="{{ mailing_list.placeholder }}"
          autocomplete="email"
          disabled
          title="Mailing list coming soon"
        />
        <button type="button" class="ml-btn" disabled>{{ mailing_list.button_label }}</button>
      </div>
      <p class="ml-coming-soon">Mailing list setup in progress — check back soon.</p>
    </div>
    {% endif %}

    <p class="ml-fine-print">{{ mailing_list.fine_print }}</p>
  </div>
</section>
{% endif %}

<style>
.sr-only {
  position: absolute;
  width: 1px;
  height: 1px;
  padding: 0;
  margin: -1px;
  overflow: hidden;
  clip: rect(0,0,0,0);
  white-space: nowrap;
  border: 0;
}
.mailing-list-section {
  background: var(--umber);
  padding: clamp(3rem, 6vw, 5rem) var(--pad);
}
.mailing-list-inner {
  max-width: 540px;
  margin: 0 auto;
  text-align: center;
}
.ml-lotus {
  margin-bottom: 20px;
  display: flex;
  justify-content: center;
}
.ml-heading {
  font-family: var(--font-display);
  font-size: clamp(26px, 4vw, 36px);
  font-weight: 300;
  color: var(--parchment);
  margin-bottom: 12px;
  line-height: 1.2;
}
.ml-sub {
  font-size: 14px;
  line-height: 1.8;
  color: var(--gold-lt);
  margin-bottom: 28px;
  max-width: 400px;
  margin-left: auto;
  margin-right: auto;
}
.ml-form {
  width: 100%;
}
.ml-input-row {
  display: flex;
  gap: 0;
  border: 0.5px solid rgba(212,184,122,0.3);
  border-radius: var(--radius-md);
  overflow: hidden;
  background: rgba(255,255,255,0.05);
}
.ml-input-row input[type="email"] {
  flex: 1;
  padding: 13px 18px;
  font-family: var(--font-body);
  font-size: 14px;
  background: transparent;
  border: none;
  color: var(--parchment);
  outline: none;
  min-width: 0;
}
.ml-input-row input[type="email"]::placeholder { color: rgba(168,144,96,0.6); }
.ml-input-row input[type="email"]:disabled { opacity: 0.5; cursor: not-allowed; }
.ml-btn {
  flex-shrink: 0;
  padding: 13px 22px;
  font-family: var(--font-body);
  font-size: 11px;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  background: var(--gold);
  color: var(--parchment);
  border: none;
  cursor: pointer;
  transition: background 0.2s;
}
.ml-btn:hover:not(:disabled) { background: var(--gold-pale); color: var(--umber); }
.ml-btn:disabled { opacity: 0.5; cursor: not-allowed; }
.ml-fine-print {
  font-size: 11px;
  color: rgba(122,96,48,0.5);
  margin-top: 14px;
  letter-spacing: 0.03em;
}
.ml-coming-soon {
  font-size: 12px;
  color: rgba(168,144,96,0.6);
  margin-top: 10px;
  font-style: italic;
}

@media (max-width: 480px) {
  .ml-input-row { flex-direction: column; }
  .ml-btn { border-radius: 0; }
}
</style>
